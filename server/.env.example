PORT=4001

# Local development (ephemeral — data lost on redeploy)
# DATABASE_PATH=./data/ledger.db

# Supabase PostgreSQL (persistent — use this in production)
# Get from Supabase: Connect → ORM → DATABASE_URL (transaction pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: force SSL for non-Supabase Postgres hosts
# DATABASE_SSL=true

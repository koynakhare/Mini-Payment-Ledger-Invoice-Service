PORT=4001

# Local development (ephemeral — data lost on redeploy)
# DATABASE_PATH=./data/ledger.db

# Supabase PostgreSQL (persistent — use this in production)
# Get from Supabase: Project Settings → Database → Connection string → URI
# Use "Transaction pooler" for serverless hosts (Render, Railway), or "Direct" for long-running VMs
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: force SSL for non-Supabase Postgres hosts
# DATABASE_SSL=true

# Optional Supabase auth (validates JWTs on GraphQL requests)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

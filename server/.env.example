PORT=4001

# Required for authentication (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Optional JWT lifetime (default: 8h). Examples: 1h, 12h, 7d
# JWT_EXPIRES_IN=8h

# Gemini API key for AI compliance review (Tier 1+) — optional; without it, review degrades gracefully
# GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional SMTP for sending invoice PDFs on "Send Invoice"
# When unset, emails are logged to the server console (dev) and send still succeeds.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="TMS Payables <you@gmail.com>"

# Local development (ephemeral — data lost on redeploy)
# DATABASE_PATH=./data/ledger.db

# Supabase PostgreSQL (persistent — use this in production)
# Get from Supabase: Connect → ORM → DATABASE_URL (transaction pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: force SSL for non-Supabase Postgres hosts
# DATABASE_SSL=true

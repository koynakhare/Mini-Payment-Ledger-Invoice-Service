{
  "name": "payment-ledger-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node ./node_modules/tsx/dist/cli.mjs src/db/migrate.ts",
    "db:seed": "node ./node_modules/tsx/dist/cli.mjs src/db/seed.ts",
    "job:overdue": "node ./node_modules/tsx/dist/cli.mjs src/jobs/overdueInvoices.ts",
    "test": "node --import tsx --test src/test/ledger.test.ts src/test/invoice.test.ts src/test/payment.test.ts src/test/refund.test.ts src/test/concurrency.test.ts src/test/currency.test.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "lodash": "^4.17.21",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.13.4",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
